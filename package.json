{
  "name": "homebridge-skydimo",
  "version": "2.0.0",
  "description": "HomeKit plugin for Skydimo ambient monitor lights — talks to the controller directly over USB using the Adalight protocol. On/off, brightness, full colour wheel, Siri, scenes, automations. No UI automation, no screen flashing. Cross-platform.",

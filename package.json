  "keywords": [
    "homebridge-plugin",
    "homekit",
    "skydimo",
    "adalight",
    "ambient",
    "lights",
    "rgb",
    "led",
    "monitor-lights",
    "ambilight"
  ],
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martinheywebteam/homebridge-skydimo.git"
  },
